{
  "manifest_version": 3,
  "name": "自选股票助手",
  "version": "1.0.0",
  "description": "实时查看自选股票行情，计算持仓收益",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "自选股票助手"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.eastmoney.com/*"
  ]
}
